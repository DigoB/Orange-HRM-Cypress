    {
      "name": "Employees",
      "item": [
        {
          "name": "Get Employee List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200)",
                  "})",
                  "",
                  "pm.test(\"Response has data array\", function () {",
                  "    const json = pm.response.json()",
                  "    pm.expect(json.data).to.be.an('array')",
                  "})",
                  "",
                  "pm.test(\"Response has meta with total\", function () {",
                  "    const json = pm.response.json()",
                  "    pm.expect(json.meta).to.have.property('total')",
                  "    pm.expect(json.meta.total).to.be.above(0)",
                  "})",
                  "",
                  "pm.test(\"Each employee has required fields\", function () {",
                  "    const json = pm.response.json()",
                  "    json.data.forEach(employee => {",
                  "        pm.expect(employee).to.have.property('empNumber')",
                  "        pm.expect(employee).to.have.property('firstName')",
                  "        pm.expect(employee).to.have.property('lastName')",
                  "        pm.expect(employee).to.have.property('employeeId')",
                  "    })",
                  "})",
                  "",
                  "pm.test(\"Response time is less than 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000)",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v2/pim/employees?limit=10&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v2",
                "pim",
                "employees"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Employee by ID",
          "event": [
