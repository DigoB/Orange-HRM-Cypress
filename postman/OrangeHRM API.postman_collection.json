            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text()",
                  "const match = html.match(/:token=\"&quot;([^&]+)&quot;\"/)",
                  "if (match) {",
                  "    pm.environment.set('csrf_token', match[1])",
                  "    console.log('CSRF Token capturado:', match[1])",
                  "} else {",
                  "    console.log('CSRF Token não encontrado')",
                  "}"
                ],
