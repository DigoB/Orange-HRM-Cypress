      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text()",
                  "const match = html.match(/name=\"_token\"\\s+value=\"([^\"]+)\"/)",
                  "if (match) {",
                  "    pm.environment.set('csrf_token', match[1])",
                  "    console.log('CSRF Token capturado:', match[1])",
                  "} else {",
                  "    console.log('CSRF Token não encontrado')",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "_username",
                  "value": "{{username}}",
                  "type": "text",
                  "uuid": "ec742d93-f7eb-4e67-ba01-8773c834c4a1"
                },
                {
                  "key": "_password",
                  "value": "{{password}}",
                  "type": "text",
                  "uuid": "b7a44b30-42bc-4b67-b5fa-0d4ed119c879"
                },
                {
                  "key": "token",
                  "value": "{{csrf_token}}",
                  "type": "text",
